<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondo"
    android:clickable="true"
    android:focusable="true">

    <com.example.aprendemoslavida.story.ConfettiView
        android:id="@+id/confettiView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.35" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_streak_overlay" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="26dp">

        <FrameLayout
            android:layout_width="150dp"
            android:layout_height="150dp">

            <View
                android:id="@+id/iconGlow"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:background="@drawable/bg_streak_icon_glow" />

            <ImageView
                android:id="@+id/streakIcon"
                android:layout_width="108dp"
                android:layout_height="108dp"
                android:layout_gravity="center"
                android:contentDescription="@string/story_streak_title"
                android:src="@drawable/ic_star" />
        </FrameLayout>

        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="-4dp"
            android:background="@drawable/bg_streak_title_chip"
            android:paddingHorizontal="18dp"
            android:paddingVertical="8dp"
            android:text="@string/story_streak_title"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_streak_card"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="16dp">

            <TextView
                android:id="@+id/bodyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/text_primary"
                android:textSize="18sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/sparkleLeft"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_streak_sparkle" />

                <ImageView
                    android:id="@+id/sparkleCenter"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginHorizontal="8dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_streak_sparkle" />

                <ImageView
                    android:id="@+id/sparkleRight"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_streak_sparkle" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tapToContinueText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_streak_hint"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="invisible" />
    </LinearLayout>

</FrameLayout>
