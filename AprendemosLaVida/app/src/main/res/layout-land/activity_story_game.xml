<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="10dp"
        android:background="#CCFFFFFF"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/scoreText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/story_score_default"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/trophyProgressContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/timeText"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toEndOf="@id/scoreText"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/trophyIcon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="4dp"
                android:contentDescription="@string/story_trophy_progress_cd"
                android:src="@drawable/ic_star"
                android:tint="@color/text_primary" />

            <TextView
                android:id="@+id/trophyCountText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/story_trophy_progress_default"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/timeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/story_time_default"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/gameplayRow"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="12dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <FrameLayout
            android:id="@+id/mapContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="10dp"
            android:layout_weight="1">

            <com.example.aprendemoslavida.story.StoryGameView
                android:id="@+id/storyGameView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <TextView
                android:id="@+id/storyToast"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="10px"
                android:alpha="0"
                android:background="@drawable/bg_toast"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:visibility="gone" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/sideControls"
            android:layout_width="200dp"
            android:layout_height="match_parent"
            android:gravity="center_horizontal|center_vertical"
            android:orientation="vertical">

            <FrameLayout
                android:id="@+id/controlsContainer"
                android:layout_width="190dp"
                android:layout_height="190dp">

                <com.example.aprendemoslavida.story.VirtualJoystickView
                    android:id="@+id/joystickView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </FrameLayout>

            <ImageButton
                android:id="@+id/storySoundButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_toast"
                android:contentDescription="@string/sound_toggle_on"
                android:padding="10dp"
                android:src="@android:drawable/ic_lock_silent_mode_off"
                android:tint="@color/text_primary" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/introOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/fondo"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="20dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:id="@+id/introSpeechGroup"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="@+id/introCharacter"
                app:layout_constraintEnd_toStartOf="@+id/introCharacter"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@+id/introCharacter">

                <LinearLayout
                    android:id="@+id/introBubbleContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_story_speech"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="18dp"
                    android:paddingBottom="14dp">

                    <TextView
                        android:id="@+id/introText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp" />

                    <LinearLayout
                        android:id="@+id/introButtonsRow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/introYesButton"
                            style="@style/Widget.Aprendemos.Button"
                            android:layout_width="96dp"
                            android:layout_height="wrap_content"
                            android:text="@string/story_intro_yes" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/introNoButton"
                            style="@style/Widget.Aprendemos.Button"
                            android:layout_width="96dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="@string/story_intro_no" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/introBackButton"
                        style="@style/Widget.Aprendemos.Button"
                        android:layout_width="160dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="12dp"
                        android:text="@string/story_intro_back"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>

            <ImageView
                android:id="@+id/introCharacter"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:contentDescription="@string/story_intro_character_cd"
                android:scaleType="fitCenter"
                android:src="@drawable/story_player_base"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/celebrationOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#E6FFFFFF"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.example.aprendemoslavida.story.ConfettiView
            android:id="@+id/confettiView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="20dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:id="@+id/celebrationSpeechGroup"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="@+id/celebrationCharacter"
                app:layout_constraintEnd_toStartOf="@+id/celebrationCharacter"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@+id/celebrationCharacter">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_story_speech"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="18dp"
                    android:paddingBottom="14dp">

                    <TextView
                        android:id="@+id/celebrationText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp" />
                </LinearLayout>
            </LinearLayout>

            <ImageView
                android:id="@+id/celebrationCharacter"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:contentDescription="@string/story_intro_character_cd"
                android:scaleType="fitCenter"
                android:src="@drawable/story_player_base"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
